# Next.js ne lit que les fichiers .env situés dans le dossier de l'app.
# Copier ce fichier vers .env.local (à côté de ce fichier) pour le développement local.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=legacy
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=legacy-web-family
