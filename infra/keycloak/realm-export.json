{
  "realm": "legacy",
  "enabled": true,
  "displayName": "Legacy",
  "displayNameHtml": "<b>Legacy</b>",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "verifyEmail": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "sslRequired": "external",
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "roles": {
    "realm": [
      { "name": "SUPER_ADMIN", "description": "Gère toute la plateforme Legacy." },
      { "name": "FUNERAL_HOME_ADMIN", "description": "Gère une entreprise de pompes funèbres." },
      { "name": "FUNERAL_ADVISOR", "description": "Accompagne les familles au sein d'une pompe funèbre." },
      { "name": "LIVING_USER", "description": "Prépare son dossier personnel de son vivant." },
      { "name": "TRUSTED_PERSON", "description": "Personne de confiance désignée par un utilisateur vivant." },
      { "name": "FAMILY_MEMBER", "description": "Proche invité dans un dossier décès." },
      { "name": "GUEST_LIMITED", "description": "Accès temporaire limité à certains documents ou tâches." }
    ]
  },
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    },
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": true,
      "priority": 50
    }
  ],
  "clients": [
    {
      "clientId": "legacy-api",
      "name": "Legacy API (NestJS)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "change_me_keycloak_client_secret",
      "redirectUris": ["http://localhost:3001/*"]
    },
    {
      "clientId": "legacy-website",
      "name": "Legacy - Site public",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"]
    },
    {
      "clientId": "legacy-web-pro",
      "name": "Legacy - Portail professionnel",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3002/*"],
      "webOrigins": ["http://localhost:3002"]
    },
    {
      "clientId": "legacy-web-family",
      "name": "Legacy - Espace famille",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3003/*"],
      "webOrigins": ["http://localhost:3003"]
    },
    {
      "clientId": "legacy-app",
      "name": "Legacy - Application Flutter",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["legacy://callback", "http://localhost:*/*"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "admin@legacy.local",
      "email": "admin@legacy.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Super",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "ChangeMe123!", "temporary": true }],
      "realmRoles": ["SUPER_ADMIN"]
    }
  ]
}
