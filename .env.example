# =============================================================================
# Legacy — Variables d'environnement (exemple)
# Copier ce fichier vers .env à la racine (et/ou dans chaque app) puis adapter.
# Ne jamais committer de vraies valeurs. Les secrets doivent rester hors du code.
# =============================================================================

# --- Environnement --------------------------------------------------------
APP_ENV=development

# --- Base de données (PostgreSQL) -----------------------------------------
DATABASE_URL=postgresql://legacy:legacy@localhost:5432/legacy?schema=public

# --- Redis / BullMQ ---------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Stockage documents (MinIO, compatible S3) ------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=legacy_minio_admin
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_BUCKET=legacy-documents
MINIO_CONSOLE_PORT=9001

# --- Authentification (Keycloak) --------------------------------------------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=legacy
KEYCLOAK_CLIENT_ID=legacy-api
KEYCLOAK_CLIENT_SECRET=change_me_keycloak_client_secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

# --- URLs applicatives -------------------------------------------------------
API_URL=http://localhost:3001
WEBSITE_URL=http://localhost:3000
WEB_PRO_URL=http://localhost:3002
WEB_FAMILY_URL=http://localhost:3003

# --- Sécurité interne ---------------------------------------------------------
# Utilisé uniquement pour signer les liens de téléchargement temporaires,
# les tokens internes de jobs et les cookies de session applicatifs.
# L'authentification des utilisateurs reste gérée par Keycloak.
JWT_SECRET=change_me_generate_a_long_random_secret
DOWNLOAD_TOKEN_TTL_SECONDS=300

# --- E-mail (SMTP) ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Legacy <no-reply@legacy.example>"

# --- Statistiques & mesure d'audience (Umami, auto-hébergé, RGPD-friendly) ---
UMAMI_URL=http://localhost:8081
UMAMI_WEBSITE_ID=change_me_after_umami_setup
UMAMI_DB_URL=postgresql://legacy:legacy@localhost:5432/umami?schema=public
NEXT_PUBLIC_UMAMI_URL=http://localhost:8081/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=change_me_after_umami_setup

# --- Divers -------------------------------------------------------------------
LOG_LEVEL=debug
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
