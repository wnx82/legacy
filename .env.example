# =============================================================================
# Legacy — Variables d'environnement (exemple)
# Copier ce fichier vers .env à la racine (et/ou dans chaque app) puis adapter.
# Ne jamais committer de vraies valeurs. Les secrets doivent rester hors du code.
# =============================================================================

# --- Environnement --------------------------------------------------------
APP_ENV=development

# --- Base de données (PostgreSQL) -----------------------------------------
DATABASE_URL=postgresql://legacy:legacy@localhost:5432/legacy?schema=public

# --- Redis / BullMQ ---------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Stockage documents (MinIO, compatible S3) ------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=legacy_minio_admin
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_BUCKET=legacy-documents
MINIO_CONSOLE_PORT=9001

# --- Authentification (Keycloak) --------------------------------------------
KEYCLOAK_URL=http://localhost:8080
# URL publique du realm (celle vue par le navigateur), utilisée par l'API pour
# valider l'émetteur (`iss`) des tokens. Dans docker-compose, KEYCLOAK_URL
# devient http://keycloak:8080 (nom de service interne) alors que les tokens
# portent toujours l'URL publique — voir infra/docker-compose.yml.
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=legacy
KEYCLOAK_CLIENT_ID=legacy-api
KEYCLOAK_CLIENT_SECRET=change_me_keycloak_client_secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

# --- URLs applicatives -------------------------------------------------------
API_URL=http://localhost:3001
WEBSITE_URL=http://localhost:3000
WEB_PRO_URL=http://localhost:3002
WEB_FAMILY_URL=http://localhost:3003

# --- Variables exposées au navigateur (Next.js) ------------------------------
# Les apps Next.js appellent l'API et Keycloak directement depuis le
# navigateur : ces variables doivent être préfixées NEXT_PUBLIC_.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=legacy
# Un client OpenID Connect public distinct par application (voir infra/keycloak/realm-export.json)
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=legacy-website

# --- Sécurité interne ---------------------------------------------------------
# Utilisé uniquement pour signer les liens de téléchargement temporaires,
# les tokens internes de jobs et les cookies de session applicatifs.
# L'authentification des utilisateurs reste gérée par Keycloak.
JWT_SECRET=change_me_generate_a_long_random_secret
DOWNLOAD_TOKEN_TTL_SECONDS=300

# --- E-mail (SMTP) ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Legacy <no-reply@legacy.example>"

# --- Statistiques & mesure d'audience (Umami, auto-hébergé, RGPD-friendly) ---
UMAMI_URL=http://localhost:8081
UMAMI_WEBSITE_ID=change_me_after_umami_setup
UMAMI_DB_URL=postgresql://legacy:legacy@localhost:5432/umami?schema=public
NEXT_PUBLIC_UMAMI_URL=http://localhost:8081/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=change_me_after_umami_setup

# --- Antivirus (optionnel) ----------------------------------------------------
# clamd (ClamAV) pour le scan des documents uploadés. Laisser CLAMAV_HOST vide
# désactive le scan (statut SKIPPED) : le checksum SHA-256 est tout de même
# recalculé. En production, pointer vers un service clamd (ex: image mkodockx/
# docker-clamav ou clamav/clamav) : CLAMAV_HOST=clamav, CLAMAV_PORT=3310.
CLAMAV_HOST=
CLAMAV_PORT=3310

# --- Sauvegardes (voir docs/backup.md) ----------------------------------------
# Clé de chiffrement AES-256 des sauvegardes (infra/scripts/backup.sh).
# Générer une valeur longue et aléatoire, la stocker hors du dépôt.
# Ex: openssl rand -base64 48
BACKUP_ENCRYPTION_KEY=

# --- Version & vérification de mise à jour ------------------------------------
# APP_VERSION est injectée au build/déploiement (Komodo) et renvoyée par
# GET /api/version. À défaut, l'API lit la version du package.json racine.
APP_VERSION=
# Vérification "mise à jour disponible" (GET /api/version-check, SUPER_ADMIN).
# Le token GitHub n'est utilisé que côté serveur — jamais exposé au navigateur.
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main

# --- Divers -------------------------------------------------------------------
LOG_LEVEL=debug
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
