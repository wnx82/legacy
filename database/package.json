{
  "name": "@legacy/database",
  "version": "0.1.0",
  "private": true,
  "description": "Schéma Prisma, migrations et seed de Legacy.",
  "main": "index.ts",
  "types": "index.ts",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "prisma:studio": "dotenv -e ../.env -- prisma studio",
    "prisma:seed": "dotenv -e ../.env -- ts-node --transpile-only seed/seed.ts",
    "prisma:reset": "dotenv -e ../.env -- prisma migrate reset"
  },
  "prisma": {
    "seed": "ts-node --transpile-only seed/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
