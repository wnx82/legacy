{
  "name": "legacy-platform",
  "version": "1.2.0",
  "private": true,
  "description": "Legacy — Préparer l'après, accompagner ceux qu'on aime. Monorepo (site public, portail pro, espace famille, API, base de données, infra).",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @legacy/database prisma:generate",
    "db:migrate": "pnpm --filter @legacy/database prisma:migrate",
    "db:seed": "pnpm --filter @legacy/database prisma:seed",
    "db:studio": "pnpm --filter @legacy/database prisma:studio",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "bump:patch": "npm version patch --no-git-tag-version && node scripts/update-readme-version.js",
    "bump:minor": "npm version minor --no-git-tag-version && node scripts/update-readme-version.js",
    "bump:major": "npm version major --no-git-tag-version && node scripts/update-readme-version.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
